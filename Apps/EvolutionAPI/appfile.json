{
	"version": "2.0",
	"title": "Evolution API",
	"name": "evolution-api",
	"icon": "https://cdn.jsdelivr.net/gh/johanpedroo/CasaOS-AppStore@main/Apps/EvolutionAPI/icon.png",
	"tagline": "REST API for WhatsApp multi-device integration",
	"overview": "Evolution API is a powerful REST API for WhatsApp integration. It allows you to create and manage WhatsApp instances, send and receive messages, manage groups, and much more through a simple HTTP interface.",
	"thumbnail": "https://cdn.jsdelivr.net/gh/johanpedroo/CasaOS-AppStore@main/Apps/EvolutionAPI/thumbnail.png",
	"screenshots": [
		"https://cdn.jsdelivr.net/gh/johanpedroo/CasaOS-AppStore@main/Apps/EvolutionAPI/screenshot-1.png",
		"https://cdn.jsdelivr.net/gh/johanpedroo/CasaOS-AppStore@main/Apps/EvolutionAPI/screenshot-2.png",
		"https://cdn.jsdelivr.net/gh/johanpedroo/CasaOS-AppStore@main/Apps/EvolutionAPI/screenshot-3.png"
	],
	"category": [
		"Communication"
	],
	"developer": {
		"name": "AtendAI / EvolutionAPI",
		"website": "https://doc.evolution-api.com",
		"donate_text": "",
		"donate_link": ""
	},
	"adaptor": {
		"name": "johanpedro",
		"website": "",
		"donate_text": "",
		"donate_link": ""
	},
	"support": "https://evolution-api.com",
	"website": "https://doc.evolution-api.com",
	"container": {
		"image": "atendai/evolution-api:v2.2.3",
		"shell": "sh",
		"privileged": false,
		"network_model": "bridge",
		"web_ui": {
			"http": "8080",
			"path": "/"
		},
		"health_check": "",
		"envs": [
			{
				"key": "SERVER_URL",
				"value": "http://localhost:8080",
				"configurable": "yes",
				"description": "Server URL for the Evolution API"
			},
			{
				"key": "AUTHENTICATION_API_KEY",
				"value": "mude-me",
				"configurable": "yes",
				"description": "API authentication key (change this!)"
			},
			{
				"key": "LOG_LEVEL",
				"value": "ERROR",
				"configurable": "yes",
				"description": "Log level: ERROR, WARN, DEBUG, LOG"
			},
			{
				"key": "DATABASE_PROVIDER",
				"value": "postgresql",
				"configurable": "yes",
				"description": "Database provider (postgresql or mongodb)"
			},
			{
				"key": "DATABASE_CONNECTION_URI",
				"value": "",
				"configurable": "yes",
				"description": "Database connection string"
			}
		],
		"ports": [
			{
				"container": "8080",
				"host": "8080",
				"type": "tcp",
				"allocation": "automatic",
				"configurable": "advanced",
				"description": "Evolution API HTTP Port"
			}
		],
		"volumes": [
			{
				"container": "/evolution/instances",
				"host": "/DATA/AppData/$AppID/instances",
				"mode": "rw",
				"allocation": "automatic",
				"configurable": "no",
				"description": "Evolution API instances data"
			}
		],
		"devices": [],
		"constraints": {
			"min_memory": 256,
			"min_storage": 512
		},
		"restart_policy": "always",
		"sysctls": [],
		"cap_add": [],
		"labels": [],
		"host_name": "",
		"cmd": []
	},
	"abilities": {
		"notification": false,
		"widgets": false,
		"authentication": false,
		"search": false,
		"upnp": false
	},
	"tips": {
		"before_install": [
			{
				"content": "After installation, change the AUTHENTICATION_API_KEY environment variable to a strong, unique key. The API will be available at http://your-casaos-ip:8080.",
				"value": ""
			}
		]
	},
	"changelog": {
		"latest_updates": "",
		"url": "https://github.com/EvolutionAPI/evolution-api/releases"
	},
	"latest_update_date": "2026-03-16"
}